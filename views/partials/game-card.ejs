<a href="/games/<%= game.slug %>" class="group glass-card block no-underline overflow-hidden transition-all duration-300 hover:border-[#CCFF00]/30 hover:shadow-[0_0_20px_rgba(204,255,0,0.1)]">
  <div class="relative aspect-[16/10] overflow-hidden">
    <img src="<%= game.cover_image || '/uploads/covers/default.png' %>" alt="<%= game.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
    <div class="absolute inset-0 bg-gradient-to-t from-surface-dim via-transparent to-transparent"></div>
    <% if (game.discount_price) { %>
      <span class="absolute top-3 left-3 bg-[#e9b3ff] text-black text-xs font-black px-2 py-1 font-['Space_Grotesk'] uppercase tracking-wider">SALE</span>
    <% } %>
    <div class="absolute bottom-3 left-3 right-3 flex justify-between items-end">
      <div>
        <span class="text-xs font-['Space_Grotesk'] uppercase tracking-widest text-slate-400"><%= game.category_name || 'Uncategorized' %></span>
        <h3 class="text-white font-['Space_Grotesk'] font-bold text-lg mt-0.5 line-clamp-1"><%= game.title %></h3>
      </div>
    </div>
  </div>
  <div class="p-4 flex justify-between items-center">
    <div class="flex items-center space-x-1">
      <span class="material-symbols-outlined text-[#CCFF00] text-sm">star</span>
      <span class="text-on-surface font-['Inter'] text-sm"><%= Number(game.rating_avg).toFixed(1) %></span>
      <span class="text-slate-500 text-xs">(<%= game.rating_count || 0 %>)</span>
    </div>
    <div class="text-right">
      <% if (game.discount_price) { %>
        <span class="text-slate-500 text-xs line-through">$<%= Number(game.price).toFixed(2) %></span>
        <span class="text-[#CCFF00] font-['Space_Grotesk'] font-bold ml-2">$<%= Number(game.discount_price).toFixed(2) %></span>
      <% } else { %>
        <span class="text-[#CCFF00] font-['Space_Grotesk'] font-bold"><%= Number(game.price) === 0 ? 'FREE' : '$' + Number(game.price).toFixed(2) %></span>
      <% } %>
    </div>
  </div>
</a>
