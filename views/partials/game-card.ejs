<div class="group glass-card overflow-hidden transition-all duration-300 hover:border-[#CCFF00]/30 hover:shadow-[0_0_20px_rgba(204,255,0,0.1)]">
  <a href="/games/<%= game.slug %>" class="block no-underline">
  <div class="relative aspect-[16/10] overflow-hidden">
    <img src="<%= game.cover_image || '/uploads/covers/default.png' %>" alt="<%= game.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
    <div class="absolute inset-0 bg-gradient-to-t from-surface-dim via-transparent to-transparent"></div>
    <div class="absolute bottom-3 left-3 right-3 flex justify-between items-end">
      <div>
        <span class="text-xs font-['Space_Grotesk'] uppercase tracking-widest text-slate-400"><%= game.category_name || t('uncategorized') %></span>
        <h3 class="text-white font-['Space_Grotesk'] font-bold text-lg mt-0.5 line-clamp-1"><%= game.title %></h3>
      </div>
    </div>
  </div>
  </a>
  <div class="p-4 flex justify-between items-center gap-3">
    <div class="flex items-center space-x-1">
      <span class="material-symbols-outlined text-[#CCFF00] text-sm">star</span>
      <span class="text-on-surface font-['Inter'] text-sm"><%= Number(game.rating_avg).toFixed(1) %></span>
      <span class="text-slate-500 text-xs">(<%= game.rating_count || 0 %>)</span>
    </div>
    <div class="text-right flex-shrink-0">
      <% if (game.download_url) { %>
        <a href="<%= game.download_url %>" target="_blank" rel="noopener" class="inline-flex items-center gap-1 bg-[#CCFF00] text-black px-3 py-1.5 font-['Space_Grotesk'] uppercase tracking-wider text-xs font-bold no-underline">
          <span class="material-symbols-outlined text-sm">download</span><%= t('download') %>
        </a>
      <% } else { %>
        <span class="text-slate-500 font-['Space_Grotesk'] uppercase tracking-wider text-xs"><%= t('downloadUnavailable') %></span>
      <% } %>
    </div>
  </div>
</div>
