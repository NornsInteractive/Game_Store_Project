          <a href="#" class="block text-slate-400 hover:text-[#CCFF00] text-sm no-underline transition-colors"><%= t('contact') %></a>
          <a href="#" class="block text-slate-400 hover:text-[#CCFF00] text-sm no-underline transition-colors"><%= t('privacy') %></a>
        </div>
      </div>
      <div>
        <h4 class="font-['Space_Grotesk'] uppercase tracking-widest text-xs font-bold text-white mb-4"><%= t('connect') %></h4>
        <div class="space-y-2">
          <span class="block text-slate-400 text-sm">Discord</span>
          <span class="block text-slate-400 text-sm">Twitter</span>
          <span class="block text-slate-400 text-sm">YouTube</span>
