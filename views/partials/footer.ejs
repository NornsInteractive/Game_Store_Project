        <div class="text-xl font-black text-[#CCFF00] italic tracking-tighter mb-4">CYBERPULSE</div>
        <p class="text-slate-500 text-sm font-['Inter']"><%= t('footerTagline') %></p>
      </div>
      <div>
        <h4 class="font-['Space_Grotesk'] uppercase tracking-widest text-xs font-bold text-white mb-4"><%= t('platform') %></h4>
        <div class="space-y-2">
          <a href="/games" class="block text-slate-400 hover:text-[#CCFF00] text-sm no-underline transition-colors"><%= t('navStore') %></a>
          <a href="/news" class="block text-slate-400 hover:text-[#CCFF00] text-sm no-underline transition-colors"><%= t('navNews') %></a>
          <a href="/dashboard/submit" class="block text-slate-400 hover:text-[#CCFF00] text-sm no-underline transition-colors"><%= t('submitGame') %></a>
