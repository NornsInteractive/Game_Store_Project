    <a href="/dashboard" class="flex items-center space-x-3 px-3 py-2.5 rounded text-sm font-['Space_Grotesk'] uppercase tracking-wider font-bold no-underline transition-all <%= path === '/dashboard' ? 'bg-[#CCFF00]/10 text-[#CCFF00]' : 'text-slate-400 hover:text-white' %>">
      <span class="material-symbols-outlined text-lg">space_dashboard</span>
      <span><%= t('dashboard') %></span>
    </a>
    <a href="/dashboard/library" class="flex items-center space-x-3 px-3 py-2.5 rounded text-sm font-['Space_Grotesk'] uppercase tracking-wider font-bold no-underline transition-all <%= path === '/dashboard/library' ? 'bg-[#CCFF00]/10 text-[#CCFF00]' : 'text-slate-400 hover:text-white' %>">
