<% if (flashSuccess) { %>
<div class="max-w-7xl mx-auto px-6 pt-4">
  <div class="glass-card border-l-2 border-[#CCFF00] p-4 flex items-center space-x-3">
    <span class="material-symbols-outlined text-[#CCFF00]">check_circle</span>
    <span class="text-on-surface font-body-md"><%= flashSuccess %></span>
  </div>
</div>
<% } %>
<% if (flashError) { %>
<div class="max-w-7xl mx-auto px-6 pt-4">
  <div class="glass-card border-l-2 border-[#ffb4ab] p-4 flex items-center space-x-3">
    <span class="material-symbols-outlined text-[#ffb4ab]">error</span>
    <span class="text-on-surface font-body-md"><%= flashError %></span>
  </div>
</div>
<% } %>
