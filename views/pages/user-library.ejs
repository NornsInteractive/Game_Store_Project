<div class="mb-8">
  <h1 class="font-headline-lg text-headline-lg text-white uppercase italic">My Library</h1>
</div>

<% if (library && library.length > 0) { %>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
  <% library.forEach(function(g) { %>
    <a href="/games/<%= g.slug %>" class="glass-card block no-underline overflow-hidden hover:border-[#CCFF00]/30 transition-all">
      <div class="aspect-[16/10] overflow-hidden">
        <img src="<%= g.cover_image || '/uploads/covers/default.png' %>" alt="<%= g.title %>" class="w-full h-full object-cover"/>
      </div>
      <div class="p-4">
        <h3 class="text-white font-['Space_Grotesk'] font-bold text-sm line-clamp-1"><%= g.title %></h3>
        <p class="text-slate-500 text-xs mt-1">Acquired <%= new Date(g.purchased_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
      </div>
    </a>
  <% }) %>
</div>
<% } else { %>
<div class="glass-card p-12 text-center">
  <span class="material-symbols-outlined text-6xl text-slate-600 mb-4">videogame_asset_off</span>
  <p class="text-slate-400 font-body-lg mb-4">Your library is empty.</p>
  <a href="/games" class="bg-[#CCFF00] text-black px-6 py-2 font-['Space_Grotesk'] uppercase tracking-wider text-sm font-bold no-underline shadow-[0_0_10px_rgba(204,255,0,0.3)] hover:shadow-[0_0_20px_rgba(204,255,0,0.5)] transition-all">Browse Games</a>
</div>
<% } %>
