<div class="mb-8">
  <h1 class="font-headline-lg text-headline-lg text-white uppercase italic"><%= t('submitGame') %></h1>
  <p class="text-slate-400 mt-2"><%= lang === 'zh' ? '向 CyberPulse 目录提交新游戏，管理员会进行审核。' : 'Propose a new title for the CyberPulse catalog. Admins will review your submission.' %></p>
</div>

<div class="max-w-3xl">
  <form method="POST" action="/dashboard/submit" class="glass-card p-8 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('title') %> *</label>
        <input type="text" name="title" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow" required/>
      </div>
      <div class="space-y-2">
        <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('developer') %></label>
        <input type="text" name="developer" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow"/>
      </div>
      <div class="space-y-2">
        <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('publisher') %></label>
        <input type="text" name="publisher" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow"/>
      </div>
      <div class="space-y-2">
        <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('downloadUrl') %></label>
        <input type="url" name="downloadUrl" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow"/>
      </div>
      <div class="space-y-2">
        <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('releaseDate') %></label>
        <input type="date" name="releaseDate" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow"/>
      </div>
      <div class="space-y-2">
        <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('category') %></label>
        <select name="categoryId" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow">
          <option value="">-- Select --</option>
          <% if (typeof categories !== 'undefined' && categories) { categories.forEach(function(c) { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) } %>
        </select>
      </div>
    </div>
    <div class="space-y-2">
      <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('tags') %></label>
      <input type="text" name="tags" placeholder="Action, RPG, Multiplayer" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow"/>
    </div>
    <div class="space-y-2">
      <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('shortDescription') %></label>
      <input type="text" name="shortDescription" maxlength="200" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow"/>
    </div>
    <div class="space-y-2">
      <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('description') %> *</label>
      <textarea name="description" rows="6" class="w-full py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow" required></textarea>
    </div>
    <button type="submit" class="bg-[#CCFF00] text-black font-['Space_Grotesk'] uppercase tracking-widest font-bold px-8 py-3 shadow-[0_0_10px_rgba(204,255,0,0.3)] hover:shadow-[0_0_20px_rgba(204,255,0,0.5)] transition-all">
      <%= t('submitForReview') %>
    </button>
  </form>
</div>
