<!-- JSON-LD Structured Data -->
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "VideoGame",
  "name": game.title,
  "description": game.short_description || (game.description ? game.description.slice(0, 200) : game.title),
  "genre": game.category_name || undefined,
  "author": game.developer ? { "@type": "Organization", "name": game.developer } : undefined,
  "publisher": game.publisher ? { "@type": "Organization", "name": game.publisher } : undefined,
  "datePublished": game.release_date || game.created_at,
  "keywords": parsedTags.join(', ') || undefined
}) %>
</script>

<!-- Hero for first game -->
<section class="relative h-[500px] w-full flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src="<%= game.hero_image || game.cover_image || '/uploads/covers/default.png' %>" class="w-full h-full object-cover" alt="<%= game.title %>"/>
    <div class="absolute inset-0 bg-gradient-to-t from-surface-dim via-surface-dim/40 to-transparent"></div>
  </div>
  <div class="container mx-auto px-8 relative z-10">
    <div class="max-w-2xl">
      <div class="flex items-center space-x-2 mb-4">
        <span class="text-xs font-['Space_Grotesk'] uppercase tracking-widest text-slate-400"><%= game.category_name || t('uncategorized') %></span>
        <% parsedTags.forEach(function(t) { %><span class="cyber-tag"><%= t %></span><% }) %>
      </div>
      <h1 class="font-display-xl text-display-xl text-white uppercase italic"><%= game.title %></h1>
      <div class="flex items-center space-x-4 mt-4">
        <span class="text-slate-500 text-sm"><%= lang === 'zh' ? '浏览量' : 'Views' %>: <%= game.views_count || 0 %></span>
        <% if (game.developer) { %><span class="text-slate-400 text-sm"><%= game.developer %></span><% } %>
      </div>
    </div>
  </div>
</section>

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 flex flex-col-reverse sm:grid sm:grid-cols-12 gap-4 sm:gap-6 md:gap-8 lg:gap-12 overflow-x-hidden">
  <div class="col-span-1 sm:col-span-12 md:col-span-8 lg:col-span-8 space-y-12">
    <section>
      <h2 class="font-headline-md text-headline-md text-white mb-4 flex items-center gap-3">
        <span class="w-2 h-8 bg-[#CCFF00]"></span> <%= t('overview') %>
      </h2>
      <p class="text-on-surface-variant font-body-md leading-relaxed w-full max-w-3xl break-words"><%= game.description %></p>
    </section>

    <% if (Object.keys(parsedSysReq).length > 0) { %>
    <section>
      <h2 class="font-headline-md text-headline-md text-white mb-6"><%= t('systemRequirements') %></h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% if (parsedSysReq.minimum) { %>
        <div class="glass-card p-6 border-l-2 border-l-[#CCFF00]">
          <h4 class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-white mb-3"><%= lang === 'zh' ? '最低配置' : 'Minimum' %></h4>
          <ul class="space-y-2 text-sm text-slate-400">
            <% Object.entries(parsedSysReq.minimum).forEach(function(e) { %>
              <li class="flex justify-between border-b border-white/5 pb-1"><span><%= e[0] %>:</span> <span class="text-white"><%= e[1] %></span></li>
            <% }) %>
          </ul>
        </div>
        <% } %>
        <% if (parsedSysReq.recommended) { %>
        <div class="glass-card p-6 border-l-2 border-l-[#e9b3ff]">
          <h4 class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-white mb-3"><%= lang === 'zh' ? '推荐配置' : 'Recommended' %></h4>
          <ul class="space-y-2 text-sm text-slate-400">
            <% Object.entries(parsedSysReq.recommended).forEach(function(e) { %>
              <li class="flex justify-between border-b border-white/5 pb-1"><span><%= e[0] %>:</span> <span class="text-white"><%= e[1] %></span></li>
            <% }) %>
          </ul>
        </div>
        <% } %>
      </div>
    </section>
    <% } %>

    <% if (parsedScreenshots.length > 0) { %>
    <section>
      <h2 class="font-headline-md text-headline-md text-white mb-6"><%= lang === 'zh' ? '截图' : 'Screenshots' %></h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <% parsedScreenshots.forEach(function(s) { %>
          <div class="glass-card overflow-hidden"><img src="<%= s %>" alt="" class="w-full aspect-video object-cover"/></div>
        <% }) %>
      </div>
    </section>
    <% } %>

    <section>
      <h2 class="font-headline-md text-headline-md text-white mb-6"><%= t('comments') %></h2>
      <div class="w-full max-w-3xl">
        <% if (disqusShortname) { %>
        <%- include('../partials/disqus-thread', {
          disqusShortname,
          pageUrl: currentUrl,
          pageIdentifier: `game:${game.id}`,
          pageTitle: game.title,
          lang
        }) %>
        <% } else { %>
        <p class="text-slate-500"><%= lang === 'zh' ? '请先配置 DISQUS_SHORTNAME 以启用评论区。' : 'Set DISQUS_SHORTNAME to enable comments.' %></p>
        <% } %>
      </div>
    </section>
  </div>

  <aside class="sm:col-span-12 md:col-span-4 lg:col-span-4 space-y-6">
    <div class="glass-card p-6 sticky top-24">
      <div class="text-center">
        <img src="<%= game.cover_image || '/uploads/covers/default.png' %>" alt="<%= game.title %>" class="w-full aspect-[3/4] object-cover mb-4"/>
        <div class="space-y-3">
          <% if (game.download_url) { %>
            <a href="<%= game.download_url %>" target="_blank" rel="noopener" class="w-full inline-flex items-center justify-center gap-2 bg-[#CCFF00] text-black font-['Space_Grotesk'] uppercase tracking-widest font-bold px-6 py-3 shadow-[0_0_10px_rgba(204,255,0,0.3)] hover:shadow-[0_0_20px_rgba(204,255,0,0.5)] transition-all no-underline">
              <span class="material-symbols-outlined">download</span><%= t('download') %>
            </a>
          <% } else { %>
            <p class="text-slate-500 font-['Space_Grotesk'] uppercase tracking-wider"><%= t('downloadUnavailable') %></p>
          <% } %>
        </div>
      </div>
    </div>
  </aside>
</div>
