<div class="max-w-4xl mx-auto px-6 py-16">
  <div class="mb-8">
    <span class="text-xs font-['Space_Grotesk'] uppercase tracking-widest text-slate-400"><%= article.category_name || 'News' %></span>
    <h1 class="font-headline-lg text-headline-lg text-white mt-2"><%= article.title %></h1>
    <div class="flex items-center space-x-4 mt-4 border-b border-white/10 pb-6">
      <div class="w-10 h-10 rounded-full bg-surface-container-high overflow-hidden">
        <% if (article.author_avatar) { %><img src="<%= article.author_avatar %>" alt="" class="w-full h-full object-cover"/><% } %>
      </div>
      <div>
        <span class="text-white font-['Space_Grotesk'] font-bold text-sm"><%= article.author_name %></span>
        <span class="block text-slate-500 text-xs"><%= new Date(article.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
      </div>
    </div>
  </div>

  <% if (article.hero_image) { %>
  <div class="mb-10 glass-card overflow-hidden">
    <img src="<%= article.hero_image %>" alt="<%= article.title %>" class="w-full max-h-96 object-cover"/>
  </div>
  <% } %>

  <div class="prose prose-invert max-w-none mb-12">
    <p class="text-on-surface-variant font-body-lg leading-relaxed whitespace-pre-line"><%= article.content %></p>
  </div>

  <section class="border-t border-white/10 pt-12">
    <h2 class="font-headline-md text-headline-md text-white mb-6">Comments</h2>
    <% if (currentUser) { %>
    <form method="POST" action="/news/<%= article.slug %>/comment" class="mb-8">
      <textarea name="content" rows="3" placeholder="Share your thoughts..." class="w-full bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface p-3 transition-all input-glow" required></textarea>
      <input type="hidden" name="parentId" value=""/>
      <button type="submit" class="mt-3 bg-[#CCFF00] text-black font-['Space_Grotesk'] uppercase tracking-wider text-sm font-bold px-6 py-2 shadow-[0_0_10px_rgba(204,255,0,0.3)] hover:shadow-[0_0_20px_rgba(204,255,0,0.5)] transition-all">Post Comment</button>
    </form>
    <% } else { %>
    <p class="mb-8 text-slate-500"><a href="/login" class="text-[#CCFF00] no-underline">Login</a> to leave a comment.</p>
    <% } %>
    <%- include('../partials/comment-thread', { comments: comments, userVotes: userVotes }) %>
  </section>
</div>
