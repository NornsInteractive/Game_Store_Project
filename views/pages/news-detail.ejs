<div class="max-w-4xl mx-auto px-6 py-16">
  <div class="mb-8">
    <span class="text-xs font-['Space_Grotesk'] uppercase tracking-widest text-slate-400"><%= article.category_name || t('news') %></span>
    <h1 class="font-headline-lg text-headline-lg text-white mt-2"><%= article.title %></h1>
    <div class="flex items-center space-x-4 mt-4 border-b border-white/10 pb-6">
      <div class="w-10 h-10 rounded-full bg-surface-container-high overflow-hidden">
        <% if (article.author_avatar) { %><img src="<%= article.author_avatar  || '/uploads/avatars/default.png' %>" alt="" class="w-full h-full object-cover"/><% } %>
      </div>
      <div>
        <span class="text-white font-['Space_Grotesk'] font-bold text-sm"><%= article.author_name %></span>
        <span class="block text-slate-500 text-xs"><%= formatDate(article.created_at) %></span>
      </div>
    </div>
  </div>

  <% if (article.hero_image) { %>
  <div class="mb-10 glass-card overflow-hidden">
    <img src="<%= article.hero_image %>" alt="<%= article.title %>" class="w-full max-h-96 object-cover"/>
  </div>
  <% } %>

  <div class="prose prose-invert max-w-none mb-12">
    <p class="text-on-surface-variant font-body-lg leading-relaxed whitespace-pre-line"><%= article.content %></p>
  </div>

  <section class="border-t border-white/10 pt-12">
    <h2 class="font-headline-md text-headline-md text-white mb-6"><%= t('comments') %></h2>
    <div class="w-full max-w-3xl">
      <% if (disqusShortname) { %>
      <%- include('../partials/disqus-thread', {
        disqusShortname,
        pageUrl: currentUrl,
        pageIdentifier: `article:${article.id}`,
        pageTitle: article.title,
        lang
      }) %>
      <% } else { %>
      <p class="text-slate-500"><%= lang === 'zh' ? '请先配置 DISQUS_SHORTNAME 以启用评论区。' : 'Set DISQUS_SHORTNAME to enable comments.' %></p>
      <% } %>
    </div>
  </section>
</div>
