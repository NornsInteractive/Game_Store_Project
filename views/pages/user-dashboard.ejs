<div class="mb-8">
  <h1 class="font-headline-lg text-headline-lg text-white uppercase italic">Dashboard</h1>
  <p class="text-slate-400 mt-2">Welcome back, <span class="text-[#CCFF00]"><%= currentUser.username %></span>.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <a href="/dashboard/library" class="glass-card p-6 no-underline block hover:border-[#CCFF00]/30 transition-all">
    <span class="material-symbols-outlined text-3xl text-[#CCFF00] mb-3">videogame_asset</span>
    <p class="text-2xl font-['Space_Grotesk'] font-bold text-white"><%= (typeof libraryCount !== 'undefined') ? libraryCount : 0 %></p>
    <p class="text-slate-500 text-xs font-['Space_Grotesk'] uppercase tracking-wider mt-1">Games Owned</p>
  </a>
  <a href="/dashboard/profile" class="glass-card p-6 no-underline block hover:border-[#e9b3ff]/30 transition-all">
    <span class="material-symbols-outlined text-3xl text-[#e9b3ff] mb-3">person</span>
    <p class="text-2xl font-['Space_Grotesk'] font-bold text-white">Edit</p>
    <p class="text-slate-500 text-xs font-['Space_Grotesk'] uppercase tracking-wider mt-1">Profile Settings</p>
  </a>
  <a href="/dashboard/submit" class="glass-card p-6 no-underline block hover:border-[#CCFF00]/30 transition-all">
    <span class="material-symbols-outlined text-3xl text-[#CCFF00] mb-3">upload</span>
    <p class="text-2xl font-['Space_Grotesk'] font-bold text-white">Submit</p>
    <p class="text-slate-500 text-xs font-['Space_Grotesk'] uppercase tracking-wider mt-1">Publish New Game</p>
  </a>
</div>

<% if (recentActivity && recentActivity.length > 0) { %>
<div class="glass-card p-6">
  <h2 class="font-headline-md text-2xl text-white mb-4">Recent Activity</h2>
  <div class="space-y-3">
    <% recentActivity.forEach(function(a) { %>
      <div class="flex items-center space-x-3 py-2 border-b border-white/5 last:border-0">
        <span class="text-[#CCFF00] text-xs font-['Space_Grotesk'] uppercase tracking-wider w-28 flex-shrink-0"><%= a.action.replace(/_/g, ' ') %></span>
        <span class="text-slate-400 text-sm font-['Inter'] flex-1">
          <% if (a.target_type === 'game') { %>Game #<%= a.target_id %><% } %>
          <% if (a.target_type === 'article') { %>Article #<%= a.target_id %><% } %>
        </span>
        <span class="text-slate-600 text-xs"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
      </div>
    <% }) %>
  </div>
</div>
<% } else { %>
<div class="glass-card p-12 text-center">
  <span class="material-symbols-outlined text-6xl text-slate-600 mb-4">history</span>
  <p class="text-slate-400">No activity yet. Start exploring the store!</p>
</div>
<% } %>
