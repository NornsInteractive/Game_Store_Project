<div class="mb-8">
  <h1 class="font-headline-lg text-headline-lg text-white uppercase italic">Game_Submissions</h1>
  <p class="text-slate-400 mt-1"><%= total %> draft titles awaiting review.</p>
</div>

<% if (submissions.length > 0) { %>
<div class="glass-card overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-white/10 text-left">
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Title</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Developer</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Price</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Category</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Date</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% submissions.forEach(function(s) { %>
      <tr class="border-b border-white/5 hover:bg-white/5">
        <td class="p-3 text-white font-['Space_Grotesk'] font-bold"><%= s.title %></td>
        <td class="p-3 text-slate-400 text-xs"><%= s.developer || '—' %></td>
        <td class="p-3 text-white">$<%= Number(s.price).toFixed(2) %></td>
        <td class="p-3 text-slate-400 text-xs"><%= s.category_name || '—' %></td>
        <td class="p-3 text-slate-400 text-xs"><%= new Date(s.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
        <td class="p-3">
          <div class="flex items-center space-x-2">
            <a href="/admin/games/<%= s.id %>/edit" class="text-[#CCFF00] hover:underline text-xs font-['Space_Grotesk'] uppercase tracking-wider no-underline">Review</a>
            <form method="POST" action="/admin/games/<%= s.id %>/status" class="inline">
              <input type="hidden" name="status" value="published"/>
              <button type="submit" class="text-[#CCFF00] hover:text-white text-xs font-['Space_Grotesk'] uppercase tracking-wider">Publish</button>
            </form>
            <form method="POST" action="/admin/games/<%= s.id %>/delete" class="inline" onsubmit="return confirm('Delete this submission?')">
              <button type="submit" class="text-red-400 hover:text-red-300 text-xs font-['Space_Grotesk'] uppercase tracking-wider">Delete</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../../partials/pagination', { page: page, pages: pages, query: {} }) %>
<% } else { %>
<div class="glass-card p-12 text-center">
  <span class="material-symbols-outlined text-6xl text-slate-600 mb-4">inbox</span>
  <p class="text-slate-400 font-body-lg">No pending submissions.</p>
</div>
<% } %>
