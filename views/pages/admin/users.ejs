<div class="mb-8 flex justify-between items-center">
  <div>
    <h1 class="font-headline-lg text-headline-lg text-white uppercase italic">User_Management</h1>
    <p class="text-slate-400 mt-1"><%= total %> registered runners.</p>
  </div>
</div>

<div class="glass-card p-4 mb-6">
  <form method="GET" action="/admin/users" class="flex items-center space-x-3">
    <input type="text" name="search" value="<%= currentSearch %>" placeholder="Search by username or email..." class="py-2 px-4 w-64 text-sm"/>
    <button type="submit" class="bg-[#CCFF00] text-black px-4 py-2 font-['Space_Grotesk'] uppercase tracking-wider text-xs font-bold">Search</button>
  </form>
</div>

<% if (users.length > 0) { %>
<div class="glass-card overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-white/10 text-left">
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">User</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Email</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Role</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Status</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Joined</th>
        <th class="p-3 font-['Space_Grotesk'] uppercase tracking-wider text-xs text-slate-400">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function(u) { %>
      <tr class="border-b border-white/5 hover:bg-white/5">
        <td class="p-3">
          <div class="flex items-center space-x-3">
            <div class="w-8 h-8 rounded-full bg-surface-container-high overflow-hidden">
              <% if (u.avatar) { %><img src="<%= u.avatar %>" alt="" class="w-full h-full object-cover"/><% } %>
            </div>
            <span class="text-white font-['Space_Grotesk'] font-bold"><%= u.username %></span>
          </div>
        </td>
        <td class="p-3 text-slate-400 text-xs"><%= u.email %></td>
        <td class="p-3">
          <span class="text-xs font-['Space_Grotesk'] uppercase tracking-wider px-2 py-0.5 <%= u.role === 'admin' ? 'bg-[#e9b3ff]/20 text-[#e9b3ff]' : 'bg-surface-container-high text-slate-400' %>"><%= u.role %></span>
        </td>
        <td class="p-3">
          <span class="text-xs font-['Space_Grotesk'] uppercase tracking-wider px-2 py-0.5 <%= u.banned_at ? 'bg-red-500/20 text-red-400' : 'bg-[#CCFF00]/20 text-[#CCFF00]' %>"><%= u.banned_at ? 'Banned' : 'Active' %></span>
        </td>
        <td class="p-3 text-slate-400 text-xs"><%= new Date(u.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
        <td class="p-3">
          <% if (u.banned_at) { %>
          <form method="POST" action="/admin/users/<%= u.id %>/unban" class="inline">
            <button type="submit" class="text-[#CCFF00] hover:text-white text-xs font-['Space_Grotesk'] uppercase tracking-wider">Unban</button>
          </form>
          <% } else { %>
          <form method="POST" action="/admin/users/<%= u.id %>/ban" class="inline" onsubmit="return confirm('Ban this user?')">
            <button type="submit" class="text-red-400 hover:text-red-300 text-xs font-['Space_Grotesk'] uppercase tracking-wider">Ban</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../../partials/pagination', { page: page, pages: pages, query: { search: currentSearch } }) %>
<% } else { %>
<div class="glass-card p-12 text-center"><p class="text-slate-400">No users found.</p></div>
<% } %>
