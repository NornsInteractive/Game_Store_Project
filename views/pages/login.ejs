<div class="min-h-screen py-12">
  <div class="max-w-7xl mx-auto px-6">
    <div class="glass-card p-12">
      <div class="text-center mb-8">
        <div class="mb-6">
          <div class="inline-block px-4 py-1 border border-[#CCFF00] text-[#CCFF00] font-['Space_Grotesk'] uppercase tracking-widest text-xs mb-4 bg-[#CCFF00]/10">SYSTEM_ACCESS</div>
        </div>
        <h1 class="font-headline-lg text-headline-lg text-white mb-2">WELCOME_BACK</h1>
        <p class="text-on-surface-variant">Initialize secure session credentials.</p>
      </div>

      <form method="POST" action="/login" class="max-w-md mx-auto space-y-6">
        <div class="space-y-2">
          <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400">Email</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">alternate_email</span>
            <input type="email" name="email" placeholder="user@cyberpulse.sys" class="w-full pl-10 py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow" required/>
          </div>
        </div>
        <div class="space-y-2">
          <div class="flex justify-between">
            <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400">Password</label>
          </div>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">lock</span>
            <input type="password" name="password" placeholder="Enter your password" class="w-full pl-10 py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow" required/>
          </div>
        </div>
        <button type="submit" class="w-full bg-[#CCFF00] text-black font-['Space_Grotesk'] uppercase tracking-widest font-black py-4 shadow-[0_0_15px_rgba(204,255,0,0.3)] hover:shadow-[0_0_30px_rgba(204,255,0,0.6)] transition-all active:scale-[0.98]">
          <span class="material-symbols-outlined align-middle mr-2">login</span>
          INITIALIZE_ACCESS
        </button>
      </form>

      <div class="text-center mt-8">
        <p class="text-slate-500 text-sm">
          <span class="font-['Space_Grotesk'] uppercase tracking-wider text-xs">No account?</span>
          <a href="/register" class="text-[#CCFF00] hover:underline ml-1 font-['Space_Grotesk'] uppercase tracking-wider text-xs no-underline">Create One</a>
        </p>
      </div>
    </div>
  </div>
</div>
