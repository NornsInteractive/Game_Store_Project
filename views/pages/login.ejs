<div class="min-h-screen py-12">
  <div class="max-w-7xl mx-auto px-6">
    <div class="glass-card p-12">
      <div class="text-center mb-8">
        <div class="mb-6">
          <div class="inline-block px-4 py-1 border border-[#CCFF00] text-[#CCFF00] font-['Space_Grotesk'] uppercase tracking-widest text-xs mb-4 bg-[#CCFF00]/10"><%= lang === 'zh' ? '管理员访问' : 'ADMIN_ACCESS' %></div>
        </div>
        <h1 class="font-headline-lg text-headline-lg text-white mb-2"><%= lang === 'zh' ? '管理员登录' : 'ADMIN_LOGIN' %></h1>
        <p class="text-on-surface-variant"><%= lang === 'zh' ? '请输入管理员账号以进入后台。' : 'Authenticate to access the admin console.' %></p>
      </div>

      <form method="POST" action="/login" class="max-w-md mx-auto space-y-6">
        <div class="space-y-2">
          <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('email') %></label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">alternate_email</span>
            <input type="email" name="email" placeholder="name@example.com" class="w-full !pl-10 pr-4 py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow" required/>
          </div>
        </div>
        <div class="space-y-2">
          <div class="flex justify-between">
            <label class="font-['Space_Grotesk'] text-xs uppercase tracking-wider text-slate-400"><%= t('password') %></label>
          </div>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">lock</span>
            <input type="password" name="password" placeholder="<%= lang === 'zh' ? '输入密码' : 'Enter your password' %>" class="w-full !pl-10 pr-4 py-3 bg-surface-container-low border-b border-outline-variant focus:border-[#CCFF00] text-on-surface transition-all input-glow" required/>
          </div>
        </div>
        <button type="submit" class="w-full bg-[#CCFF00] text-black font-['Space_Grotesk'] uppercase tracking-widest font-black py-4 shadow-[0_0_15px_rgba(204,255,0,0.3)] hover:shadow-[0_0_30px_rgba(204,255,0,0.6)] transition-all active:scale-[0.98]">
          <span class="material-symbols-outlined align-middle mr-2">login</span>
          <%= lang === 'zh' ? '进入后台' : 'ENTER_CONSOLE' %>
        </button>
      </form>
    </div>
  </div>
</div>
